apiVersion: v1
kind: Secret
metadata:
  name: wazuh-credentials
  namespace: wazuh
type: Opaque
stringData:
  # OpenSearch admin password (used by dashboard + manager filebeat)
  indexer-admin-password: "CHANGE_ME"
  # Wazuh API credentials (used by dashboard to query manager API)
  api-username: "wazuh-wui"
  api-password: "CHANGE_ME"
  # OpenSearch internal server user (used by dashboard internally)
  dashboard-username: "kibanaserver"
  dashboard-password: "kibanaserver"
  # ntfy integration credentials (used by manager to send alerts)
  ntfy-username: "wazuh-integration"
  ntfy-password: "CHANGE_ME"
